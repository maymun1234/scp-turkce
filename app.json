{
  "name": "scp Türkçe",
  "slug": "scp-turkce",
  "version": "1.1.1",
  "orientation": "portrait",
  "icon": "./assets/images/icon.png",
  "scheme": "scpturkce",
  "userInterfaceStyle": "automatic",
  "newArchEnabled": true,
  "ios": {
    "supportsTablet": true
  },
  "android": {
    "permissions": [
      "com.google.android.gms.permission.AD_ID",
      "INTERNET",
      "ACCESS_NETWORK_STATE"
    ],
    "adaptiveIcon": {
      "foregroundImage": "./assets/images/android-icon-foreground.png",
      "backgroundColor": "#c0392b"
    },
    "edgeToEdgeEnabled": true,
    "predictiveBackGestureEnabled": false,
    "package": "com.bercanayd.scpturkce",
    "versionCode": 14
  },
  "web": {
    "output": "static",
    "favicon": "./assets/images/favicon.png"
  },
  "plugins": [
    [
      "expo-navigation-bar",
      {
        "backgroundColor": "#1c1c1e",
        "barStyle": "light-content",
        "borderColor": "#1f2937",
        "visibility": "visible",
        "behavior": "inset-swipe",
        "position": "relative"
      }
    ],
    [
      "expo-quick-actions",
      {
        "iosActions": [
          {
            "id": "random-scp",
            "title": "Rastgele SCP",
            "subtitle": "Rastgele bir SCP aç",
            "icon": "symbol:shuffle",
            "params": {
              "action": "random"
            }
          },
          {
            "id": "favourites",
            "title": "Favorilerim",
            "subtitle": "Kayıtlı SCP'leri görüntüle",
            "icon": "symbol:heart.fill",
            "params": {
              "action": "favourites"
            }
          },
          {
            "id": "filter",
            "title": "Filtrele",
            "subtitle": "SCP'leri filtrele",
            "icon": "symbol:line.3.horizontal.decrease.circle",
            "params": {
              "action": "filter"
            }
          }
        ]
      }
    ],
    "expo-router",
    [
      "react-native-google-mobile-ads",
      {
        "androidAppId": "ca-app-pub-7345089833984227~4442183202",
        "iosAppId": "ca-app-pub-7345089833984227~4442183202"
      }
    ],
    [
      "expo-splash-screen",
      {
        "image": "./assets/images/splash.png",
        "imageWidth": 150,
        "resizeMode": "contain",
        "backgroundColor": "#ffffff",
        "dark": {
          "backgroundColor": "#000000",
          "image": "./assets/images/splashblack.png"
        }
      }
    ],
    "expo-tracking-transparency",
    [
      "expo-build-properties",
      {
        "android": {
          "enableProguardInReleaseBuilds": true,
          "extraProguardRules": "-keep class com.google.android.gms.** { *; }",
          "enableMinifyInReleaseBuilds": true,
          "usesCleartextTraffic": true,
          "navigationBar": {
            "barStyle": "dark-content"
          }
        },
        "ios": {
          "useFrameworks": "static"
        }
      }
    ],
    "expo-font"
  ],
  "experiments": {
    "typedRoutes": true
  },
  "extra": {
    "router": {},
    "eas": {
      "projectId": "dd3765b0-ac15-4eda-9c7e-3f11e77649f8"
    }
  },
  "sdkVersion": "54.0.0",
  "platforms": [
    "ios",
    "android",
    "web"
  ],
  "androidStatusBar": {
    "backgroundColor": "#ffffff"
  },
  "owner": "bercanayd2"
}
