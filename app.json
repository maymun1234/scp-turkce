{
  "name": "scp Türkçe",
  "slug": "scp-turkce",
  "version": "1.1.0",
  "orientation": "portrait",
  "icon": "./assets/images/icon.png",
  "scheme": "scpturkce",
  "userInterfaceStyle": "automatic",
  "newArchEnabled": true,
  "ios": {
    "supportsTablet": true
  },
  "android": {
    "permissions": [
      "com.google.android.gms.permission.AD_ID"
    ],
    "adaptiveIcon": {
      "foregroundImage": "./assets/images/android-icon-foreground.png",
      "backgroundColor": "#ffffff"
    },
    "edgeToEdgeEnabled": true,
    "predictiveBackGestureEnabled": false,
    "package": "com.bercanayd.scpturkce"
  },
  "web": {
    "output": "static",
    "favicon": "./assets/images/favicon.png"
  },
  "plugins": [
    "expo-router",
    [
      "react-native-google-mobile-ads",
      {
        "androidAppId": "ca-app-pub-7345089833984227~4442183202",
        "iosAppId": "ca-app-pub-7345089833984227~4442183202"
      }
    ],
    [
      "expo-splash-screen",
      {
        "image": "./assets/images/splash.png",
        "imageWidth": 150,
        "resizeMode": "contain",
        "backgroundColor": "#ffffff",
        "dark": {
          "backgroundColor": "#000000"
        }
      }
    ],
    "expo-tracking-transparency",
    [
      "expo-build-properties",
      {
        "android": {
          "enableProguardInReleaseBuilds": true,
          "extraProguardRules": "-keep class com.google.android.gms.** { *; }",
          "enableMinifyInReleaseBuilds": true
        },
        "ios": {
          "useFrameworks": "static"
        }
      }
    ]
  ],
  "experiments": {
    "typedRoutes": true
  },
  "extra": {
    "router": {},
    "eas": {
      "projectId": "bdb78ead-6462-4e9c-8aed-0cfe365a07d5"
    }
  },
  "sdkVersion": "54.0.0",
  "platforms": [
    "ios",
    "android",
    "web"
  ],
  "androidStatusBar": {
    "backgroundColor": "#ffffff"
  }
}